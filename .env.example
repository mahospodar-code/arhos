# ARHOS Atelier — Environment Variables
# Skopíruj tento súbor ako .env.local pre lokálny vývoj
# Na Verceli nastav tieto premenné v Project Settings > Environment Variables

# Admin heslo (klientska strana - musí súhlasiť s ADMIN_PASSWORD na serveri)
VITE_ADMIN_PASSWORD=arhos2026

# Cloudinary (pre nahrávanie obrázkov v Admin)
VITE_CLOUDINARY_CLOUD_NAME=dm5dsjnjk
VITE_CLOUDINARY_UPLOAD_PRESET=arhos_unsigned

# === SERVEROVÉ PREMENNÉ (len Vercel, nie v .env.local) ===
# GitHub token pre publikovanie cez Admin
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=mahospodar-code
GITHUB_REPO_NAME=arhos

# Admin heslo (server-side overenie v api/publish.js)
ADMIN_PASSWORD=arhos2026
