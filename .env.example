# ARHOS ateliér — premenné prostredia
# Skopíruj ako .env.local pre lokálny vývoj (npm run dev)
# Na Verceli nastav v Project Settings → Environment Variables

# Heslo do /admin (klientská strana — vidno v bundli, slúži len ako brána do UI)
VITE_ADMIN_PASSWORD=zmen-si-toto-heslo

# Cloudinary — nahrávanie fotiek v /admin (unsigned upload, cloud dm5dsjnjk)
VITE_CLOUDINARY_CLOUD_NAME=dm5dsjnjk
VITE_CLOUDINARY_UPLOAD_PRESET=arhos_unsigned

# === Len server (Vercel), nikdy nedávaj do .env.local s VITE_ prefixom ===
# GitHub token s právom "repo" — /admin ním commitne src/data/projects.json
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO_OWNER=mahospodar-code
GITHUB_REPO_NAME=arhos

# Skutočné heslo overované na serveri (api/publish.js) — musí sedieť s VITE_ADMIN_PASSWORD
ADMIN_PASSWORD=zmen-si-toto-heslo
